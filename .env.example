# ============================================================
# Supremacia Digital — variáveis de ambiente (exemplo)
# Copie para .env.local (gitignored) e preencha.
# ============================================================

# Multiplayer (Supabase). Se ausentes, o jogo usa o adapter LOCAL simulado
# (localStorage + BroadcastChannel) e o multiplayer online fica desabilitado.
# A anon key é PÚBLICA por design (protegida por RLS) — pode ir no bundle.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ------------------------------------------------------------
# OpenRouter — usado APENAS por scripts locais de geração de arte
# (ex.: gerar texturas/ícones via Gemini em tempo de build/dev).
# É um SECRET de cobrança: NUNCA prefixar com VITE_ (senão vaza no bundle
# do navegador) e NUNCA usar em código do cliente. Só Node/scripts locais.
# Pegue a chave em https://openrouter.ai/keys
# ------------------------------------------------------------
OPENROUTER_API_KEY=
